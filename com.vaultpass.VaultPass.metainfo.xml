<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.vaultpass.VaultPass</id>
  <name>VaultPass</name>
  <summary>Gestionnaire de mots de passe sécurisé pour GNOME</summary>
  <summary xml:lang="en">Secure password manager for GNOME</summary>
  
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>AGPL-3.0-or-later</project_license>
  
  <description>
    <p>
      VaultPass est un gestionnaire de mots de passe sécurisé et open source,
      conçu pour l'environnement de bureau GNOME. Il offre une sécurité de niveau
      militaire avec chiffrement AES-256-GCM et dérivation de clé Argon2id.
    </p>
    <p xml:lang="en">
      VaultPass is a secure, open source password manager designed for the
      GNOME desktop environment. It offers military-grade security with
      AES-256-GCM encryption and Argon2id key derivation.
    </p>
    <p>Fonctionnalités principales:</p>
    <ul>
      <li>Chiffrement AES-256-GCM (norme NIST)</li>
      <li>Dérivation de clé Argon2id (recommandé OWASP)</li>
      <li>Générateur de mots de passe sécurisé</li>
      <li>Verrouillage automatique configurable</li>
      <li>Import depuis Bitwarden et CSV</li>
      <li>Notes chiffrées intégrées</li>
      <li>Thèmes visuels (Nord, Catppuccin, Everforest)</li>
      <li>Interface GTK4 moderne conforme GNOME HIG</li>
    </ul>
  </description>
  
  <launchable type="desktop-id">com.vaultpass.VaultPass.desktop</launchable>
  
