{
  "app-id": "io.github.UbuntuFR.VaultpassNative",
  "runtime": "org.gnome.Platform",
  "runtime-version": "49",
  "sdk": "org.gnome.Sdk",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.rust-stable"
  ],
  "command": "vaultpass-native",
  "finish-args": [
    "--share=ipc",
    "--socket=wayland",
    "--socket=fallback-x11",
    "--device=dri",
    "--filesystem=~/.local/share/vaultpass:create",
    "--own-name=io.github.UbuntuFR.VaultpassNative"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin",
    "env": {
      "CARGO_HOME": "/run/build/vaultpass-native/cargo-home",
      "RUST_BACKTRACE": "1"
    }
  },
  "modules": [
    {
      "name": "vaultpass-native",
      "buildsystem": "simple",
      "build-options": {
        "append-path": "/usr/lib/sdk/rust-stable/bin"
      },
      "build-commands": [
        "cargo --offline build --release 2>&1",
        "install -Dm755 target/release/vaultpass-native /app/bin/vaultpass-native"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "."
        },
        {
          "type": "file",
          "path": ".cargo-config.toml",
          "dest-filename": ".cargo/config.toml"
        }
      ],
      "post-install": [
        "install -Dm644 data/io.github.UbuntuFR.VaultpassNative.metainfo.xml /app/share/metainfo/io.github.UbuntuFR.VaultpassNative.metainfo.xml",
        "mkdir -p /app/share/dbus-1/services",
        "printf '[D-BUS Service]\nName=io.github.UbuntuFR.VaultpassNative\nExec=/app/bin/vaultpass-native\n' > /app/share/dbus-1/services/io.github.UbuntuFR.VaultpassNative.service"
      ]
    }
  ]
}
